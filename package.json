{
  "name": "codetyper",
  "displayName": "codetyper",
  "description": "MonkeyType for code templates",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.110.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "codetyper.start",
        "title": "CodeTyper: Start"
      },
      {
        "command": "codetyper.stop",
        "title": "CodeTyper: Stop"
      },
      {
        "command": "codetyper.restart",
        "title": "CodeTyper: Restart"
      }
    ],
    "configuration": {
      "title": "CodeTyper",
      "properties": {
        "codetyper.templatesFolder": {
          "type": "string",
          "default": "",
          "description": "Absolute path to your templates folder (e.g. /home/user/cp-templates)"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "pnpm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "pnpm run compile && pnpm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.110.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "typescript-eslint": "^8.56.1",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  }
}
