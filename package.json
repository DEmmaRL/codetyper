{
  "name": "codetyper",
  "displayName": "codetyper",
  "description": "MonkeyType for code templates",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.110.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:codetyper.start",
    "onCommand:codetyper.stop",
    "onCommand:codetyper.restart",
    "onCommand:codetyper.toggleBlind",
    "onCommand:codetyper.togglePreview",
    "onCommand:codetyper.history"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "codetyper.start",
        "title": "CodeTyper: Start"
      },
      {
        "command": "codetyper.stop",
        "title": "CodeTyper: Stop"
      },
      {
        "command": "codetyper.restart",
        "title": "CodeTyper: Restart"
      },
      {
        "command": "codetyper.history",
        "title": "CodeTyper: History"
      },
      {
        "command": "codetyper.toggleBlind",
        "title": "CodeTyper: Toggle Blind Mode"
      },
      {
        "command": "codetyper.togglePreview",
        "title": "CodeTyper: Toggle Preview"
      }
    ],
    "configuration": {
      "title": "CodeTyper",
      "properties": {
        "codetyper.defaultMode": {
          "type": "string",
          "enum": ["ghost", "blind"],
          "default": "ghost",
          "description": "Default typing mode: 'ghost' shows hints and highlights, 'blind' hides them"
        },
        "codetyper.showPreview": {
          "type": "boolean",
          "default": true,
          "description": "Show the template in a side panel when a session starts"
        },
        "codetyper.maxHistory": {
          "type": "number",
          "default": 1000,
          "minimum": 1,
          "maximum": 10000,
          "description": "Maximum number of session records to keep in history"
        },
        "codetyper.templatesFolder": {
          "type": "string",
          "default": "",
          "description": "Absolute path to your templates folder (e.g. /home/user/cp-templates)"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "pnpm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "pnpm run compile && pnpm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.110.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "typescript-eslint": "^8.56.1",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  }
}
